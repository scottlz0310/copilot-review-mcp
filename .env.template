# GitHub OAuth App 設定（必須）
# https://github.com/settings/developers で OAuth App を作成し、
# Authorization callback URL を $BASE_URL/callback に設定する。
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# MCP サーバーの公開 URL
BASE_URL=http://localhost:8083

# 任意項目（既定値で問題なければ未設定で可）
GITHUB_OAUTH_SCOPES=repo,user
MCP_PORT=8083
LOG_LEVEL=info
SESSION_TTL_MIN=10
TOKEN_CACHE_TTL_MIN=30
TOKEN_EXPIRES_IN_SEC=7776000
SQLITE_PATH=/data/copilot-review.db
IN_PROGRESS_THRESHOLD_SEC=30
