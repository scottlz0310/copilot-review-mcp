# copilot-review-mcp v3.0.0+ — mcp-gateway required
# Standalone OAuth has been removed. Connect this server behind mcp-gateway.
# See README.md for setup instructions.

# Optional (defaults shown)
MCP_PORT=8083
LOG_LEVEL=info
SQLITE_PATH=/data/copilot-review.db
IN_PROGRESS_THRESHOLD_SEC=30
# Streamable HTTP セッションの idle timeout（分）。
# 既定 0 = idle で閉じない（#14 対策）。DELETE を送らずに消えたクライアントの session は残るため、
# メモリ増加を抑えたい場合は正の値（例: 24 時間なら 1440）を指定する。
MCP_SESSION_TIMEOUT_MIN=0
